# SQL Server — SA account password (min 8 chars, uppercase, number, symbol required)
SA_PASSWORD=YourStrong!Passw0rd

# Python connection settings
# For Docker: keep DB_HOST=sql-server
# For local:  set DB_HOST to your SQL Server instance (e.g. localhost\SQLEXPRESS)
DB_HOST=sql-server
DB_NAME=LaplaceImmo
DB_PASSWORD=YourStrong!Passw0rd
DB_DRIVER=ODBC Driver 18 for SQL Server
